# Discord bot token
# Get this from: Discord Developer Portal → Your App → Bot → Token
# Click "Reset Token" to generate one if you haven't already
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord server (guild) ID
# How to get it: Enable Developer Mode in Discord (User Settings → Advanced → Developer Mode),
# then right-click the server icon in the sidebar and choose "Copy Server ID"
DISCORD_GUILD_ID=your_guild_id_here

# Anthropic API key (used by chat.py to call Claude)
# Get this from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
